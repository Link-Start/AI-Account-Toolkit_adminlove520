{
  "manifest_version": 3,
  "name": "来不及解释了快上车",
  "version": "4.2.0",
  "description": "自动向 ChatGPT workspace 发送加入申请，支持多 workspace ID、已加入车队管理、下车、Gmail 别名生成和凭证转换及快捷登录。",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "sidePanel",
    "browsingData"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://auth.openai.com/*"
  ],
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "ChatGPT Workspace Joiner",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://auth.openai.com/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  }
}
